# Project-scoped secrets for candidate-app. Copy to .env in this folder
# and fill in. NEVER committed (projects-config/*/.env is gitignored).

# Fine-grained PAT scoped to THIS project's repo only
# (contents + pull requests, read/write).
GITHUB_TOKEN=

# Where this project deploys (deploy tool only; agents never see these).
GCP_PROJECT=kaggle-codelab1
GCP_REGION=australia-southeast2

# Protects the candidate app's chaos/config endpoint.
CONFIG_TOKEN=

# Local checkout of the project repo (agents branch and test here).
CANDIDATE_APP_DIR=../candidate-app
