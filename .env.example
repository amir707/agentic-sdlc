# Engine-level secrets. Copy to .env and fill in. NEVER commit .env.
# Project-scoped secrets (GitHub PAT, GCP target, config token) live in
# projects-config/<name>/.env instead — see
# projects-config/candidate-app/.env.example.

# --- model keys ---
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Coder gets the strongest coding model (via LiteLLM); reviewer is a
# different family (Gemini, ADK-native) to decorrelate failure modes.
CODER_MODEL=anthropic/claude-sonnet-5
REVIEWER_MODEL=gemini-flash-latest

# --- delivery-store MCP server (localhost) ---
DELIVERY_STORE_PORT=8787
DELIVERY_STORE_DB=delivery_store.sqlite3
# Per-caller role tokens: distinct random strings. Only the monitor
# token can open incidents / record health samples; only the resolver
# token can resolve incidents.
MCP_TOKEN_AGENTS=
MCP_TOKEN_MONITOR=
MCP_TOKEN_RESOLVER=
